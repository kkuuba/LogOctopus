# URL of the LogOctopus Flask backend.
# During development the Vite proxy (vite.config.js) forwards /api/* to this
# address automatically, so you can leave VITE_API_BASE empty and let the
# proxy handle it.
#
# For a production build served from a different origin, set this to the full
# base URL of the backend, e.g.:
#   VITE_API_BASE=https://logoctopus.example.com
#
VITE_API_BASE=
